<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Thumbnail Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@color/surface_variant">

                <!-- Thumbnail Image -->
                <ImageView
                    android:id="@+id/thumbnailImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@string/cd_thumbnail"
                    tools:visibility="visible" />

                <!-- Placeholder -->
                <FrameLayout
                    android:id="@+id/placeholderView"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_background">

                    <TextView
                        android:id="@+id/placeholderText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="24sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        tools:text="G" />

                </FrameLayout>

            </FrameLayout>

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    tools:text="Bookmark Title" />

                <!-- Notes (if any) -->
                <TextView
                    android:id="@+id/notesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:textStyle="italic"
                    android:visibility="gone"
                    tools:text="My notes about this bookmark"
                    tools:visibility="visible" />

                <!-- Domain and Favorite -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/domainText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        tools:text="example.com" />

                    <ImageView
                        android:id="@+id/favoriteButton"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_favorite"
                        android:src="@android:drawable/btn_star_big_off" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Selection Overlay -->
        <View
            android:id="@+id/selectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#806750A4"
            android:visibility="gone" />

        <!-- Check Icon for Selection -->
        <ImageView
            android:id="@+id/checkIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@android:drawable/checkbox_on_background"
            android:visibility="gone"
            android:contentDescription="@null" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
